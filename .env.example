# ============================================================
# Domain-Adaptive Retrieval System — 環境變數模板
# 使用方式: 複製此檔案為 .env，再依實際環境修改值
#   cp .env.example .env
# ============================================================

# -------------------- Ollama 設定 --------------------
# Docker Compose 內部網路中 Ollama 服務的位址
# 若在容器外直接執行，改為 http://localhost:11434
OLLAMA_HOST=http://ollama:11434

# Ollama 用於合成資料的模型名稱
# 建議: 8GB VRAM 環境使用 7B 量化模型，13B 有 OOM 風險
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M

# -------------------- GPU 設定 --------------------
# 指定可見的 GPU 裝置編號 (單卡環境固定為 0)
CUDA_VISIBLE_DEVICES=0

# PyTorch CUDA 記憶體分配策略
# expandable_segments 可減少記憶體碎片化，建議保持開啟
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# -------------------- HuggingFace 設定 --------------------
# 模型快取路徑 (避免重複下載，容器重啟後仍保留)
HF_HOME=/app/models/base_models
# 若在中國大陸或網路受限環境，可設定鏡像
# HF_ENDPOINT=https://hf-mirror.com

# -------------------- 隨機種子 --------------------
# 全域隨機種子，確保實驗可重現
GLOBAL_SEED=42

# -------------------- 日誌等級 --------------------
# 可選: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
